Package: gpss
Title: Gaussian Processes for Social Science
Version: 1.0.1
Date: 2026-03-20
Authors@R:
   c(person("Soonhong", "Cho", , "tnsehdtm@gmail.com", role = c("aut")),
    person("Doeun", "Kim", , "doeun2@ucla.edu", role = c("aut"),
           comment = c(ORCID = "0000-0003-4789-6599")),
